{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["next-env.d.ts", "src/**/*", "app/**/*", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "lib/testing", ".next"]
}
